{
  "tables": {
    "order_item_pricing_metrics": {
      "source": "processed",
      "owner": "src.features.pricing_features",
      "description": "Order-item grain pricing fact table used for all revenue, discount, margin proxy, and time-series diagnostics.",
      "grain": "one row per order_item_id",
      "primary_key": ["order_item_id"],
      "not_null_keys": ["order_item_id", "order_id", "order_date", "order_month", "customer_id", "product_id", "line_revenue", "line_list_revenue", "discount_depth", "high_discount_flag", "margin_proxy_pct"],
      "required_columns": [
        "order_item_id",
        "order_id",
        "order_date",
        "order_month",
        "customer_id",
        "product_id",
        "segment",
        "region",
        "category",
        "sales_channel",
        "line_revenue",
        "line_list_revenue",
        "realized_price",
        "list_price_at_sale",
        "discount_depth",
        "high_discount_flag",
        "margin_proxy_pct"
      ],
      "bounds": [
        {"column": "line_revenue", "min": 0.0},
        {"column": "line_list_revenue", "min": 0.0},
        {"column": "realized_price", "min": 0.0},
        {"column": "list_price_at_sale", "min": 0.0},
        {"column": "discount_depth", "min": 0.0, "max": 0.7},
        {"column": "high_discount_flag", "min": 0, "max": 1},
        {"column": "margin_proxy_pct", "min": -0.25, "max": 1.0}
      ]
    },
    "customer_pricing_profile": {
      "source": "processed",
      "owner": "src.features.pricing_features",
      "description": "Customer-level pricing behavior profile used as the input to governance risk scoring.",
      "grain": "one row per customer_id with at least one order",
      "primary_key": ["customer_id"],
      "not_null_keys": ["customer_id", "total_orders", "total_revenue", "avg_discount_pct", "share_orders_discounted", "share_orders_high_discount", "revenue_high_discount_share", "avg_margin_proxy_pct", "realized_price_cv", "repeat_discount_behavior"],
      "required_columns": [
        "customer_id",
        "segment",
        "region",
        "total_orders",
        "total_revenue",
        "avg_discount_pct",
        "share_orders_discounted",
        "share_orders_high_discount",
        "revenue_high_discount_share",
        "avg_margin_proxy_pct",
        "realized_price_cv",
        "repeat_discount_behavior"
      ],
      "bounds": [
        {"column": "total_orders", "min": 1},
        {"column": "total_revenue", "min": 0.0},
        {"column": "avg_discount_pct", "min": 0.0, "max": 0.7},
        {"column": "share_orders_discounted", "min": 0.0, "max": 1.0},
        {"column": "share_orders_high_discount", "min": 0.0, "max": 1.0},
        {"column": "revenue_high_discount_share", "min": 0.0, "max": 1.0},
        {"column": "avg_margin_proxy_pct", "min": 0.0, "max": 1.0},
        {"column": "realized_price_cv", "min": 0.0},
        {"column": "repeat_discount_behavior", "min": 0.0, "max": 1.0}
      ]
    },
    "customer_risk_scores": {
      "source": "processed",
      "owner": "src.scoring.risk_scoring",
      "description": "Customer-level operational governance score. It is a prioritization heuristic, not a causal or predictive model.",
      "grain": "one row per customer_id with score components and recommended action",
      "primary_key": ["customer_id"],
      "not_null_keys": ["customer_id", "pricing_risk_score", "discount_dependency_score", "margin_erosion_score", "governance_priority_score", "main_risk_driver", "risk_tier", "recommended_action", "low_data_flag"],
      "required_columns": [
        "customer_id",
        "pricing_risk_score",
        "discount_dependency_score",
        "margin_erosion_score",
        "governance_priority_score",
        "main_risk_driver",
        "risk_tier",
        "recommended_action",
        "low_data_flag"
      ],
      "bounds": [
        {"column": "pricing_risk_score", "min": 0.0, "max": 100.0},
        {"column": "discount_dependency_score", "min": 0.0, "max": 100.0},
        {"column": "margin_erosion_score", "min": 0.0, "max": 100.0},
        {"column": "governance_priority_score", "min": 0.0, "max": 100.0},
        {"column": "low_data_flag", "min": 0, "max": 1}
      ],
      "allowed_values": {
        "risk_tier": ["Low", "Medium", "High", "Critical"]
      }
    },
    "segment_pricing_summary": {
      "source": "processed",
      "owner": "src.features.pricing_features",
      "description": "Segment-level pricing quality summary with margin proxy and mix-normalized residual dispersion.",
      "grain": "one row per segment",
      "primary_key": ["segment"],
      "not_null_keys": ["segment", "total_revenue", "avg_discount_pct", "median_discount_pct", "share_high_discount", "avg_margin_proxy_pct", "realized_price_residual_std", "realized_price_residual_abs_mean", "margin_erosion_proxy"],
      "required_columns": [
        "segment",
        "total_revenue",
        "avg_discount_pct",
        "median_discount_pct",
        "share_high_discount",
        "avg_margin_proxy_pct",
        "realized_price_residual_std",
        "realized_price_residual_abs_mean",
        "margin_erosion_proxy"
      ],
      "bounds": [
        {"column": "total_revenue", "min": 0.0},
        {"column": "avg_discount_pct", "min": 0.0, "max": 0.7},
        {"column": "share_high_discount", "min": 0.0, "max": 1.0},
        {"column": "avg_margin_proxy_pct", "min": 0.0, "max": 1.0},
        {"column": "realized_price_residual_abs_mean", "min": 0.0},
        {"column": "margin_erosion_proxy", "min": 0.0}
      ]
    },
    "overall_pricing_health": {
      "source": "output",
      "csv": "overall_pricing_health.csv",
      "owner": "src.analysis.formal_analysis",
      "description": "Portfolio-level pricing health snapshot derived from processed order-item facts.",
      "grain": "one row per pipeline run",
      "primary_key": [],
      "not_null_keys": ["total_revenue", "weighted_realized_discount", "price_realization", "high_discount_revenue_share", "margin_proxy_pct"],
      "required_columns": [
        "total_revenue",
        "weighted_realized_discount",
        "price_realization",
        "high_discount_revenue_share",
        "margin_proxy_pct"
      ],
      "bounds": [
        {"column": "total_revenue", "min": 0.0},
        {"column": "weighted_realized_discount", "min": 0.0, "max": 1.0},
        {"column": "price_realization", "min": 0.0, "max": 1.0},
        {"column": "high_discount_revenue_share", "min": 0.0, "max": 1.0},
        {"column": "margin_proxy_pct", "min": 0.0, "max": 1.0}
      ]
    }
  }
}
